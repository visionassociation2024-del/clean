DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full
PORT=4000
NODE_ENV=development
AUTO_INIT_DB=true

# Required in production. Use long, unique values and never commit real secrets.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@eliteclean.sa
ADMIN_PASSWORD=change-this-password
ADMIN_TOKEN_SECRET=replace-with-at-least-32-random-characters

# Comma-separated production origins, for example:
ALLOWED_ORIGINS=https://eliteclean.sa,https://www.eliteclean.sa
